    <string name="home_delay_info_desc">Informações sobre o uso prolongado do anel</string>
    <string name="home_delay_info_message"><![CDATA[
        <b>Você esqueceu de remover o anel</b><br><br>
        <b>Anel mantido por 3–4 semanas</b>: A proteção contraceptiva permanece. Remova o anel, faça uma semana de intervalo (quando geralmente ocorre o sangramento) e depois insira um novo anel.<br><br>
        <b>Anel mantido por mais de 4 semanas</b>: A proteção contraceptiva pode ser reduzida — há risco de gravidez. Remova o anel imediatamente e entre em contato com seu médico antes de inserir um novo (pode ser necessário um teste de gravidez ou contracepção adicional).<br><br>
        <b>Nota</b>: Se não ocorrer sangramento após a remoção do anel, procure também orientação médica.<br><br>
        ]]></string>
    <string name="home_delay_info_title">Info</string>
    <string name="home_delay_message">Por quantos dias a mais o anel foi usado?</string>
