<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/default_bg"
        android:contentDescription="@string/home_background_desc" />

    <View
        android:id="@+id/background_dim_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:background="@android:color/transparent">

        <FrameLayout
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_marginBottom="16dp">

            <com.darexsh.veri_aristo.HomeCircleView
                android:id="@+id/circularProgress"
                android:layout_width="400dp"
                android:layout_height="400dp"
                android:padding="60dp"
                android:layout_gravity="center" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_days_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/home_days"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_days_left_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/home_days_left"
                    android:textSize="18sp" />
            </LinearLayout>

        </FrameLayout>

        <TextView
            android:id="@+id/tv_removal_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:autoSizeMaxTextSize="16sp"
            android:autoSizeMinTextSize="12sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/home_removal_on_placeholder" />

        <TextView
            android:id="@+id/tv_secondary_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:autoSizeMaxTextSize="14sp"
            android:autoSizeMinTextSize="11sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/home_insertion_on_placeholder" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/home_delay_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="74dp"
        android:background="@drawable/bg_special_actions_panel"
        android:padding="8dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_delay_info"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/round_icon_button"
                android:clickable="true"
                android:contentDescription="@string/home_delay_info_desc"
                android:focusable="true"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="i"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold|italic" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delay_cycle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="220dp"
                android:text="@string/btn_delay_cycle"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                app:backgroundTint="#6200EE"
                app:cornerRadius="12dp"
                app:elevation="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_skip_ring_free_info"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/round_icon_button"
                android:clickable="true"
                android:contentDescription="@string/home_skip_ring_free_info_desc"
                android:focusable="true"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="i"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold|italic" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_skip_ring_free_week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="220dp"
                android:text="@string/btn_skip_ring_free_week"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                app:backgroundTint="#6200EE"
                app:cornerRadius="12dp"
                app:elevation="2dp" />
        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_special_actions_toggle"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:contentDescription="@string/home_special_actions_toggle_open"
        android:text="@string/home_special_actions_label"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        app:backgroundTint="#A61A1D2A"
        app:cornerRadius="21dp"
        app:elevation="3dp"
        app:icon="@drawable/ic_special_cases"
        app:iconGravity="textStart"
        app:iconPadding="6dp"
        app:iconTint="#FFFFFF"
        app:strokeColor="#66FFFFFF"
        app:strokeWidth="1dp" />

    <FrameLayout
        android:id="@+id/update_hero_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginStart="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="0dp"
        android:alpha="0"
        android:translationY="-16dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/update_hero_card"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_update_hero_glass"
            android:elevation="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <FrameLayout
                android:id="@+id/update_hero_status_badge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_update_hero_chip"
                android:clipChildren="false"
                android:clipToPadding="false">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lav_update_hero_status"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="center"
                    app:lottie_autoPlay="false"
                    app:lottie_loop="false" />

                <TextView
                    android:id="@+id/tv_update_hero_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:alpha="0"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="✓"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:id="@+id/update_hero_orbit_icon"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="center"
                    android:visibility="gone">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_update_orbit_glow" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_update_orbit_ring"
                        android:translationX="-2dp" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_update_orbit_ring"
                        android:translationX="2dp" />

                    <View
                        android:layout_width="3dp"
                        android:layout_height="3dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_update_orbit_dot" />
                </FrameLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/tv_update_hero_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:text="@string/update_startup_latest"
                android:textColor="#ECF6FF"
                android:textSize="14sp"
                android:textStyle="normal" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
