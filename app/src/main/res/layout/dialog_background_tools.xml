<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_background_tools_pick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_set_background"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#6200EE"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_background_tools_hint_pick"
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_background_tools_all_screens"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#6200EE"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_background_tools_hint_all_screens"
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_background_tools_dim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#6200EE"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_background_tools_hint_dim"
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_background_tools_blur"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#6200EE"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_background_tools_hint_blur"
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</ScrollView>
