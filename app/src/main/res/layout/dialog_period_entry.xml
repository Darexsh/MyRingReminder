<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/period_modal_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="10dp"
    android:paddingEnd="16dp"
    android:paddingBottom="4dp">

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_period_day"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/period_modal_period_day"
        android:textSize="16sp"
        android:textStyle="bold"
        app:useMaterialThemeColors="true" />

    <TextView
        android:id="@+id/tv_period_intensity_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/period_modal_intensity_title"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_intensity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true"
        app:selectionRequired="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_intensity_light"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/period_modal_intensity_light" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_intensity_medium"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/period_modal_intensity_medium" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_intensity_heavy"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/period_modal_intensity_heavy" />
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:id="@+id/tv_period_pain_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/period_modal_pain_title"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_pain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true"
        app:selectionRequired="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_pain_light"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:checkedIconVisible="true"
            android:text="@string/period_modal_pain_light" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_pain_medium"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:checkedIconVisible="true"
            android:text="@string/period_modal_pain_medium" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_pain_strong"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:checkedIconVisible="true"
            android:text="@string/period_modal_pain_strong" />
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:id="@+id/tv_period_symptoms_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/period_modal_symptoms_title"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_symptoms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleLine="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_symptom_illness"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/period_modal_illness" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_symptom_nausea"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/period_modal_symptom_nausea" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_symptom_fatigue"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/period_modal_symptom_fatigue" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_symptom_dizziness"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/period_modal_symptom_dizziness" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_symptom_diarrhea"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/period_modal_symptom_diarrhea" />
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:id="@+id/tv_period_markers_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/period_modal_markers_title"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_markers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleLine="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_start"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/period_modal_start_marker" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_end"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/period_modal_end_marker" />
    </com.google.android.material.chip.ChipGroup>

    <LinearLayout
        android:id="@+id/period_modal_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_period_delete"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="@string/period_modal_clear"
            android:textAllCaps="false" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_period_cancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:minWidth="0dp"
            android:text="@string/dialog_cancel"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_period_save"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="@string/dialog_ok"
            android:textAllCaps="false"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
