    <string name="tour_body_settings_button_color">Ändere die Akzentfarbe für Buttons.\nDies ändert auch den Widget-Hintergrund.</string>
    <string name="tour_body_settings_calendar">Lege fest, wie weit der Kalender vergangene und zukünftige Zyklen anzeigt.</string>
